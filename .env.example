# --- Discord (required unless DRY_RUN is set) ---
BOT_TOKEN=
APPLICATION_ID=
USER_ID=

# --- AzuraCast source ---
# Base URL of your AzuraCast instance and the station shortcode to read.
AZURACAST_BASE_URL=https://hails.live
STATION_SHORTCODE=radio

# --- Widget behaviour (all optional, defaults shown) ---
# Username shown on the widget. Defaults to the station name from the API.
#WIDGET_USERNAME=
# How often to poll now-playing (ms).
#POLL_INTERVAL_MS=9000
# How often to refresh the slow endpoints: station details, schedule, requests (ms).
#META_REFRESH_MS=60000
# How many history_N_* / request_N_* field sets to generate.
#HISTORY_DEPTH=4
#REQUESTS_DEPTH=4
# Optional comma-separated allowlist that pushes only these field names (default: all).
#ENABLED_FIELDS=track_title,artist,album,album_art,listeners
# Set to 1 to print the field catalog with live values instead of sending to Discord.
# Useful for previewing every available field with no Discord credentials.
#DRY_RUN=0
